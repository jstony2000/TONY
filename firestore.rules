rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['patron', 'start', 'config'])
        && data.keys().size() == 3
        && data.patron is list
        && data.patron.size() == 42
        && data.start is string
        && data.start.size() <= 20
        && data.config is map;
    }

    function isValidTurn(data) {
      // Turn data can have type or extraHours or both
      return (data.keys().hasAny(['type', 'extraHours']))
        && (data.get('type', 0) is int)
        && (data.get('extraHours', 0) is number || data.get('extraHours', 0) is int);
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
      
      match /turns/{dateStr} {
        allow get: if isOwner(userId) && isValidId(dateStr);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(dateStr) && isValidTurn(incoming());
        allow update: if isOwner(userId) && isValidId(dateStr) && isValidTurn(incoming());
        allow delete: if isOwner(userId) && isValidId(dateStr);
      }
    }
  }
}
